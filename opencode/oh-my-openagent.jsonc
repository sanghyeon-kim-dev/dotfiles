{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/dev/assets/oh-my-opencode.schema.json",

  "agents": {
    // Primary orchestrator — Claude Opus preferred, GPT-5.4 fallback
    "sisyphus": {
      "model": "anthropic/claude-opus-4-6",
      "ultrawork": { "model": "anthropic/claude-opus-4-6" },
      "fallback_models": ["openai/gpt-5.4"]
    },

    // Architecture/reasoning — GPT-5.4 excels at principle-driven reasoning
    "oracle": { "model": "openai/gpt-5.4", "variant": "high" },

    // Planning — dual-model: Claude for iteration, GPT for structure
    "prometheus": {
      "fallback_models": ["openai/gpt-5.4"]
    },

    // Fast search/retrieval agents — Copilot Grok is ideal here
    "explore": { "model": "github-copilot/grok-code-fast-1" },
    "librarian": { "model": "github-copilot/grok-code-fast-1" }
  },

  "categories": {
    "quick": { "model": "openai/gpt-5.4-mini" },
    "unspecified-low": { "model": "anthropic/claude-sonnet-4-6" },
    "unspecified-high": { "model": "anthropic/claude-opus-4-6" },
    "ultrabrain": { "model": "openai/gpt-5.4", "variant": "xhigh" }
  },

  "runtime_fallback": true,

  "experimental": {
    "aggressive_truncation": true,
    "task_system": true
  }
}
